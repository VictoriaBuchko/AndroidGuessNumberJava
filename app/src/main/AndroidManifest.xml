<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!--
            MenuActivity — главный экран.
            intent-filter говорит системе: запускать именно этот Activity при старте приложения.
        -->
        <activity
            android:name=".MenuActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Экран: человек угадывает число -->
        <activity android:name=".HumanGuessActivity" />

        <!-- Экран: Android угадывает число -->
        <activity android:name=".AndroidGuessActivity" />

        <!-- Старый MainActivity из задания 1 — оставляем, не трогаем -->
        <activity android:name=".MainActivity" />

    </application>

</manifest>
